rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========== 輔助函式 ==========
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(teacherUid) {
      return isSignedIn() && request.auth.uid == teacherUid;
    }

    // 是否在班級的 sharedWith 清單裡（共享進來的科任老師）
    function isShared(classData) {
      return isSignedIn()
        && classData != null
        && classData.sharedWith is list
        && (request.auth.uid in classData.sharedWith);
    }

    // 取得班級資料（rules 內 get 會算 1 次讀取，呼叫端要意識成本）
    function classOf(classId) {
      return get(/databases/$(database)/documents/classes/$(classId)).data;
    }

    // 是否能讀取該班級（班導本人 OR 共享進來的老師）
    function canReadClass(classData) {
      return isOwner(classData.teacherUid) || isShared(classData);
    }

    // ========== 班級 classes ==========
    match /classes/{classId} {
      // get：班導本人 / 共享進來的 / 持 docId 且該班有 shareToken（給 join 流程驗證 token）
      // list 仍然嚴格：只有 owner 或 sharedWith 的才能列出，避免任何人廣掃 collection
      allow get: if isSignedIn() && (
        resource == null
        || canReadClass(resource.data)
        || resource.data.shareToken is string
      );
      allow list: if isSignedIn() && (
        resource == null || canReadClass(resource.data)
      );

      // 建立：必須是登入者本人為 teacherUid
      allow create: if isSignedIn()
        && request.resource.data.teacherUid == request.auth.uid;

      // 更新：兩種合法情境
      //  (a) 班導完整更新（teacherUid 不變）
      //  (b) 共享進來的人持有 token 加自己進 sharedWith：
      //      - teacherUid 不能改、shareToken 必須一致、其他欄位不能變
      //      - 只允許 sharedWith 從原本基礎上 append 自己 uid
      allow update: if isSignedIn() && (
        // (a) 班導
        isOwner(resource.data.teacherUid)
        ||
        // (b) 加入流程
        (
          request.resource.data.teacherUid == resource.data.teacherUid
          && resource.data.shareToken is string
          && request.resource.data.shareToken == resource.data.shareToken
          && request.resource.data.sharedWith is list
          && (
            // 沒有 sharedWith 時，新清單只能是 [自己]
            (!('sharedWith' in resource.data) && request.resource.data.sharedWith == [request.auth.uid])
            ||
            // 有 sharedWith 時，新清單必須等於 (舊清單 ∪ {自己})
            (
              resource.data.sharedWith is list
              && request.auth.uid in request.resource.data.sharedWith
              && request.resource.data.sharedWith.toSet() == resource.data.sharedWith.toSet().union([request.auth.uid].toSet())
            )
          )
          // 其他欄位（name / createdAt 等）不能在這個分支被改
          && request.resource.data.name == resource.data.name
        )
      );

      // 刪除：僅班導本人
      allow delete: if isOwner(resource.data.teacherUid);
    }

    // ========== 學生 students ==========
    // students 透過 classOf(classId) 反查班級權限
    // 寫入只允許班導（共享進來的老師唯讀）
    match /students/{studentId} {
      allow read: if isSignedIn() && (
        // 讀取：可讀該班級者皆可
        resource == null
          ? false
          : canReadClass(classOf(resource.data.classId))
      );

      allow create: if isSignedIn()
        && isOwner(classOf(request.resource.data.classId).teacherUid);

      allow update, delete: if isSignedIn()
        && resource != null
        && isOwner(classOf(resource.data.classId).teacherUid);
    }

    // ========== 戰績 scores ==========
    // 戰績完全獨立：新寫入必帶 teacherUid，讀取只看自己
    // 兼容：v3.10 前的舊資料沒 teacherUid 欄位，先允許所有登入者可讀（避免戰績消失）
    //       直到 migration 補完 teacherUid 後可緊縮
    match /scores/{scoreId} {
      allow read: if isSignedIn()
        && resource != null
        && (
          !('teacherUid' in resource.data)
          || resource.data.teacherUid == request.auth.uid
        );

      allow create: if isSignedIn()
        && request.resource.data.teacherUid == request.auth.uid;

      allow update, delete: if isSignedIn()
        && resource != null
        && resource.data.teacherUid == request.auth.uid;
    }

    // ========== 辨認統計 recognition_stats ==========
    match /recognition_stats/{statId} {
      allow read, write: if isSignedIn()
        && (resource == null || resource.data.teacherUid == request.auth.uid);
    }

    // ========== 班級攻略本 class_insights ==========
    // 攻略本由班導產生並擁有；共享老師可讀取（看班導建好的內容）
    match /class_insights/{classId} {
      allow read: if isSignedIn() && (
        resource == null
          ? false
          : (resource.data.teacherUid == request.auth.uid
              || isShared(classOf(classId)))
      );

      allow create: if isSignedIn()
        && request.resource.data.teacherUid == request.auth.uid;

      allow update, delete: if isSignedIn()
        && resource != null
        && resource.data.teacherUid == request.auth.uid;
    }

    // ========== 預設拒絕 ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
